{
	"name": "Python 3",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
	// Es necesario añadir el host de docker para que funcione el docker in docker
	"features": {
		"ghcr.io/devcontainers/features/aws-cli:1.1.1": {},
		"ghcr.io/devcontainers/features/kubectl-helm-minikube": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"version": "latest",
			"moby": true,
			"dockerDashComposeVersion": "v1",
			"privileged": true
		  }
	  },
	"customizations": {
    // Configure properties specific to VS Code.
    "vscode": {
      // Add the IDs of extensions you want installed when the container is created.
      "extensions": [
		"ms-azuretools.vscode-docker",
        "discretegames.f5anything",
        "Github.copilot",
        "GitHub.copilot-chat",
		"bierner.markdown-mermaid",
		"ms-kubernetes-tools.vscode-kubernetes-tools",
        "chriso.vscode-kubeval",
        "ms-kubernetes-tools.vscode-helm",
		"cweijan.vscode-postgresql-client2",
		"bierner.markdown-mermaid"
      ]}
	},

	//"mounts": ["source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"]
	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "pip3 install -r requirements.txt",
	"postStartCommand": "./k8s/aws/init.sh"
	

}
